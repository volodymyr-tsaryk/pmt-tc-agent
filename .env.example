# Required
ANTHROPIC_API_KEY=sk-ant-...

# SSL: set to 0 to allow self-signed certificates (e.g. corporate proxy, local dev)
# WARNING: disables TLS verification — do not use in production
NODE_TLS_REJECT_UNAUTHORIZED=0

# Optional
PORT=3000

# Phase 2: Trello (uncomment when connecting real API)
# TRELLO_API_KEY=
# TRELLO_TOKEN=

# Phase 2: Asana (uncomment when connecting real API)
# ASANA_TOKEN=

# GitHub Issues integration (real API)
GITHUB_TOKEN=            # Required: PAT with repo/public_repo scope
GITHUB_WEBHOOK_SECRET=   # Required when GITHUB_TOKEN is set: secret configured in GitHub webhook settings
GITHUB_TRIGGER_LABEL=ai-review# Label that triggers analysis (default: ai-review)
GITHUB_MENTION=@pmt-tc-agent# Mention keyword in comments (default: @task-ai)
GITHUB_BOT_USERNAME=pmt-tc-agent# Optional: GitHub username of the bot account — prevents agent replying to its own comments
