# Required
ANTHROPIC_API_KEY=sk-ant-...

# SSL: set to 0 to allow self-signed certificates (e.g. corporate proxy, local dev)
# WARNING: disables TLS verification — do not use in production
NODE_TLS_REJECT_UNAUTHORIZED=0

# Optional
PORT=3000

# Phase 2: Trello (uncomment when connecting real API)
# TRELLO_API_KEY=
# TRELLO_TOKEN=

# Phase 2: Asana (uncomment when connecting real API)
# ASANA_TOKEN=
