{
  "name": "pmt-tc-agent",
  "version": "1.0.0",
  "description": "AI agent that analyzes project management tasks",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:trello": "curl -X POST http://localhost:3000/webhook/trello -H 'Content-Type: application/json' -d '{\"taskId\": \"TRELLO-001\"}'",
    "test:asana": "curl -X POST http://localhost:3000/webhook/asana -H 'Content-Type: application/json' -d '{\"taskId\": \"ASANA-001\"}'",
    "test:github:label": "TEST_OWNER=octocat TEST_REPO=Hello-World TEST_ISSUE=1 npx ts-node scripts/test-github-label.ts",
    "test:github:comment": "TEST_OWNER=octocat TEST_REPO=Hello-World TEST_ISSUE=1 npx ts-node scripts/test-github-comment.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.17",
    "@mastra/core": "^0.7.0",
    "@octokit/rest": "^20.1.2",
    "ai": "^4.1.46",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
